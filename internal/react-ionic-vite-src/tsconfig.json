{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"jsx": "react-jsx",
		"noEmit": true,
		"types": ["vite/client", "node"],
		"lib": ["DOM", "ESNext", "DOM.Iterable"],
		"paths": {
			"@/*": ["./*"]
		}
	},
	"exclude": ["node_modules", "android", "ios"]
}
